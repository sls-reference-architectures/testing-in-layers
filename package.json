{
  "name": "testing-in-layers",
  "version": "1.0.0",
  "description": "A reference project to demonstrate testing at unit, int, and e2e layers",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "test": "npm run lint && npx jest unit.test --collectCoverage --collectCoverageFrom=src/**/*.js --silent",
    "deploy": "npx sls deploy -s dev",
    "teardown": "npx sls remove -s dev",
    "test:int": "STAGE=dev npx jest int.test --config jest.config.int.js --silent",
    "test:e2e": "STAGE=dev npx jest e2e.test --config jest.config.e2e.js --silent"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sls-reference-architectures/testing-in-layers.git"
  },
  "author": "Seth Orell",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sls-reference-architectures/testing-in-layers/issues"
  },
  "homepage": "https://github.com/sls-reference-architectures/testing-in-layers#readme",
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.734.0",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^9.4.0",
    "@swc/core": "^1.11.21",
    "@swc/jest": "^0.2.39",
    "aws-testing-library": "^4.0.7",
    "axios": "^1.18.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-extended": "^7.0.0",
    "osls": "^4.0.0",
    "serverless-deployment-bucket": "^1.5.1",
    "serverless-esbuild": "^1.54.6",
    "serverless-iam-roles-per-function": "^3.2.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.734.0",
    "@aws-sdk/lib-dynamodb": "^3.1086.0",
    "@dazn/lambda-powertools-logger": "^1.28.1",
    "@middy/core": "^7.5.0",
    "@middy/http-error-handler": "^7.5.0",
    "@middy/http-json-body-parser": "^7.5.0",
    "http-errors": "^2.0.1",
    "joi": "^17.13.4",
    "ulid": "^3.0.2"
  }
}
